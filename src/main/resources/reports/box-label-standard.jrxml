<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="box_label_standard"
              pageWidth="595"
              pageHeight="420"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              uuid="fd847355-58de-47a1-89e5-1a83064baf3f">
    <parameter name="QR_IMAGE" class="java.awt.Image"/>
    <parameter name="BARCODE_IMAGE" class="java.awt.Image"/>
    <parameter name="LOGO_IMAGE" class="java.awt.Image"/>
    <field name="boxLabelName" class="java.lang.String"/>
    <field name="inventoryName" class="java.lang.String"/>
    <field name="packageSpec" class="java.lang.String"/>
    <field name="brandName" class="java.lang.String"/>
    <field name="productionDate" class="java.lang.String"/>
    <field name="shift" class="java.lang.String"/>
    <field name="storageCondition" class="java.lang.String"/>
    <field name="shelfLife" class="java.lang.String"/>
    <field name="productBarcode" class="java.lang.String"/>
    <field name="company" class="java.lang.String"/>
    <field name="address" class="java.lang.String"/>
    <field name="contact" class="java.lang.String"/>
    <field name="productionLicenseNo" class="java.lang.String"/>
    <field name="productStandardNo" class="java.lang.String"/>
    <field name="ingredients" class="java.lang.String"/>
    <field name="nutritionFacts" class="java.lang.String"/>
    <field name="netContent" class="java.lang.String"/>
    <detail>
        <band height="380">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="380"/>
            </rectangle>
            <staticText>
                <reportElement x="18" y="14" width="130" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[箱贴通用模板]]></text>
            </staticText>
            <textField>
                <reportElement x="95" y="45" width="320" height="44"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="24" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{boxLabelName}]]></textFieldExpression>
            </textField>
            <image onErrorType="Blank">
                <reportElement x="18" y="40" width="65" height="52"/>
                <imageExpression><![CDATA[$P{LOGO_IMAGE}]]></imageExpression>
            </image>
            <image scaleImage="RetainShape">
                <reportElement x="455" y="22" width="80" height="80"/>
                <imageExpression><![CDATA[$P{QR_IMAGE}]]></imageExpression>
            </image>
            <textField>
                <reportElement x="24" y="105" width="250" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["存货名称: " + $F{inventoryName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="290" y="105" width="235" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["装箱规格: " + $F{packageSpec}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="24" y="132" width="250" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["品牌: " + $F{brandName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="290" y="132" width="235" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["生产日期: " + $F{productionDate} + "  班次: " + $F{shift}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="24" y="159" width="250" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["贮存条件: " + $F{storageCondition}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="290" y="159" width="235" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["保质期: " + $F{shelfLife}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="24" y="188" width="510" height="32"/>
                <textElement verticalAlignment="Top">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["配料表: " + $F{ingredients}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="24" y="224" width="250" height="28"/>
                <textElement verticalAlignment="Top">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{nutritionFacts}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="290" y="224" width="235" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{netContent}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="24" y="260" width="510" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["生产商: " + $F{company}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="24" y="284" width="510" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["地址: " + $F{address} + "  联系方式: " + $F{contact}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="24" y="308" width="510" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["生产许可证号: " + $F{productionLicenseNo} + "  产品标准号: " + $F{productStandardNo}]]></textFieldExpression>
            </textField>
            <image scaleImage="RetainShape">
                <reportElement x="182" y="326" width="190" height="42"/>
                <imageExpression><![CDATA[$P{BARCODE_IMAGE}]]></imageExpression>
            </image>
            <textField>
                <reportElement x="190" y="365" width="175" height="12"/>
                <textElement textAlignment="Center">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{productBarcode}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
